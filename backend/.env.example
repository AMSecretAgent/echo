# Copy to .env and fill in. Everything is optional — the app runs without any of it.

# ---- LLM provider (powers analysis, generation, clone replies, AND screenshot reading) ----
# Echo speaks the OpenAI format, so it works with Groq / Gemini / OpenAI / local.
# Leave the key blank to use the built-in local fallback (screenshots need a real key).
#
#  GROQ (free, no card) — get a key at https://console.groq.com
#     LLM_API_KEY=gsk_xxxxxxxx
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_MODEL=llama-3.3-70b-versatile     # or openai/gpt-oss-120b (bigger free daily limit)
#
#  GEMINI (free tier, no card) — get a key at https://aistudio.google.com/apikey
#     LLM_API_KEY=AIza-xxxxxxxx
#     LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#     LLM_MODEL=gemini-2.5-flash
#
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# LLM_VISION_MODEL=        # only set if your text model can't read images

# ---- Payments ----
ECHO_UPI_VPA=creator@upi
ECHO_CREATOR_NAME=Aarohi

# ---- URLs ----
ECHO_PUBLIC_BASE=
ECHO_FRONTEND_URL=http://localhost:5173

# ---- Real Instagram connect (optional) ----
# Create an app at https://developers.facebook.com (add the Instagram product), switch the
# target account to Business/Creator, add it as a tester (works without full App Review),
# and use an https redirect (e.g. an ngrok tunnel) that matches the app dashboard.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/instagram/callback

# ---- Real YouTube connect (free, just an API key) ----
# console.cloud.google.com -> enable "YouTube Data API v3" -> Credentials -> API key
YOUTUBE_API_KEY=