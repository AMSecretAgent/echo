# Optional: any OpenAI-compatible chat completions endpoint.
# Blank LLM_API_KEY = local keyword-based fallback engine (no key needed).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# UPI checkout page
ECHO_UPI_VPA=creator@upi
ECHO_CREATOR_NAME=Aarohi

# Public base URL used when generating trackable /r/{id} links in production
ECHO_PUBLIC_BASE=http://localhost:8000

# Retry gating thresholds for the agent graph
DEMAND_CONFIDENCE_THRESHOLD=0.55
MARKET_SCORE_THRESHOLD=50
MAX_AGENT_RETRIES=2
